  "tppManifestFile": "SRManifest.csv",
  "timerIntervalInMinutes": 60,
  "IS_RELEASE_CANDIDATE": false,
  "SubscriberAgreementConfiguration": {
    "BaseUrl": "https://your-api-base-url.example.com",
    "ActiveAgreementsRelativeUrl": "/api/subscriberAgreements",
