{
  "Logging": {
    "EventLog": {
      "SourceName": "ISL.TPP.Importer",
      "LogName": "ISL.TPP",
      "LogLevel": {
        "Default": "Information"
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "blobStorages": [
    {
      "name": "DEV",
      "enabled": true,
      "azureBlobServiceUri": "replace value",
      "azureTenantId": "replace value",
      "azureClientId": "replace value",
      "azureClientSecret": "replace value",
      "azureBlobContainer": "tppLandings"
    }
  ],
  "tppFolders": {
    "unprocessed": "Archived",
    "processed": "Processed",
    "reProcess": "ReProcess",
    "errored": "Errored"
  },
